# Local development — use your Neon connection string or Docker Postgres
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Required — generate with: openssl rand -base64 32
SESSION_SECRET="change-me-in-production"

# Dev dashboard at /dev — set a strong password; leave unset to disable
DEV_ADMIN_SECRET="your-dev-password-here"

# Demo account password for `npm run db:seed` only (never commit a real value)
SEED_DEMO_PASSWORD="choose-a-local-demo-password"
